/**
 * Interactive Scene-Based Lesson Template Registry
 * 
 * Comprehensive template library showcasing the full power of the platform.
 * 36 templates across 12 categories demonstrating various learning patterns.
 */

import {
  LessonTemplate,
  TemplateMetadata,
  TemplateCategory,
  TemplateComponent,
  createScene,
  createPlaceholder,
  DEFAULT_TEMPLATE_SETTINGS,
} from './template-types';
import { Scene, SceneSection, SceneBackground, SceneNavigation } from './scene-types';

// ============================================
// HELPER: Create Block
// ============================================

function createBlock(
  id: string,
  type: string,
  props: Record<string, any>
): { id: string; type: string; props: Record<string, any> } {
  return { id, type, props };
}

function createSection(
  id: string,
  title?: string,
  blocks: any[] = []
): SceneSection {
  return { id, title, blocks };
}

