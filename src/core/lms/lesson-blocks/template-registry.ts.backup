          createSection('dir-sec', 'Conversation Continues', [
            createBlock('dir-response', 'text', { text: 'Your direct approach gets straight to the point. They seem slightly surprised but engaged.' }),
            createBlock('dir-npc', 'quote', { text: '"[NPC response to direct approach]"', author: '[Character Name]' }),
          ]),
        ],
      }),
    ],
  },
  placeholders: [
    createPlaceholder('character-name', 'text', 'Character Name', { sceneId: 'setup', sectionId: 'setup-sec', blockId: 'setup-character', property: 'text' }),
    createPlaceholder('npc-opening', 'text', 'NPC Opening Line', { sceneId: 'dialogue-1', sectionId: 'dlg1-sec', blockId: 'dlg1-npc', property: 'text' }),
  ],
};

// ============================================
// EXPORT TEMPLATE REGISTRY
// ============================================

export const INTERACTIVE_TEMPLATES: Record<string, LessonTemplate> = {
  // Category 1: Narrative
  'guided-story-lesson': guidedStoryLesson,
  'personal-story-lesson': personalStoryLesson,
  'documentary-lesson': documentaryLesson,
  
  // Category 2: Exploration
  'interactive-exploration': interactiveExplorationLesson,
  'interactive-map': interactiveMapLesson,
  'interactive-diagram': interactiveDiagramLesson,
  
  // Category 3: Step-Based
  'step-by-step-tutorial': stepByStepTutorial,
  'process-flow': processFlowLesson,
  'checklist-guided': checklistGuidedLesson,
  
  // Category 4: Scenario
  'choose-your-path': chooseYourPathScenario,
  'branching-simulation': branchingSimulation,
  'roleplay-dialogue': roleplayDialogueLesson,
};

export const TEMPLATE_LIST = Object.values(INTERACTIVE_TEMPLATES);

export function getTemplatesByCategory(category: TemplateCategory): LessonTemplate[] {
  return TEMPLATE_LIST.filter(t => t.metadata.category === category);
}

export function getFeaturedTemplates(): LessonTemplate[] {
  return TEMPLATE_LIST.filter(t => t.metadata.featured);
}

export function getTemplateById(id: string): LessonTemplate | undefined {
  return INTERACTIVE_TEMPLATES[id];
}

export default INTERACTIVE_TEMPLATES;
