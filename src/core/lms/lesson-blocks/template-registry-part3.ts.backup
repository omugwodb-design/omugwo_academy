/**
 * Interactive Scene-Based Lesson Template Registry - Part 3
 * 
 * Categories 9-12: Microlearning, Immersive, Gamified, Hybrid
 */

import {
  LessonTemplate,
  createScene,
  createPlaceholder,
  DEFAULT_TEMPLATE_SETTINGS,
} from './template-types';
import { SceneSection } from './scene-types';

// ============================================
// HELPER FUNCTIONS
// ============================================

function createBlock(
  id: string,
  type: string,
  props: Record<string, any>
): { id: string; type: string; props: Record<string, any> } {
  return { id, type, props };
}

function createSection(
  id: string,
  title?: string,
  blocks: any[] = []
): SceneSection {
  return { id, title, blocks };
}

